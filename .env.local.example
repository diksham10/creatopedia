# Example environment variables for local development
# Copy this to `.env.local` (or `.env`) and fill values. DO NOT commit real secrets.

# App
ENVIRONMENT=development
DEBUG=true
APP_NAME=PromptHub API
COOKIE_DOMAIN=

# Database (Postgres)
# Example: postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/prompthub_dev

# Auth / JWT
# Generate a long random SECRET_KEY (e.g. `openssl rand -base64 32`)
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Internal API (used by frontend server to call protected backend endpoints)
INTERNAL_API_SECRET=change-me-internal-secret
# Optional: comma-separated list of allowed caller IPs for internal API (e.g. "1.2.3.4,5.6.7.8")
INTERNAL_API_ALLOWLIST=

# Subdomain blacklist (comma-separated)
SUBDOMAIN_BLACKLIST=www,admin,api,mail,ftp,localhost

# Cron / jobs
CRON_SECRET=change-me-cron-secret

# Backblaze B2 / S3-compatible storage (optional)
B2_ENDPOINT_URL=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_PUBLIC_URL=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / SMTP
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Other optional deployment values
# COOKIE_DOMAIN example: .yourdomain.com (sets Domain= on cookies)
# COOKIE_DOMAIN=

# NOTE:
# - Keep real secrets out of the repository. Use your host's secrets manager or CI/CD
#   environment variables in production.
# - When deploying: ensure `INTERNAL_API_SECRET` in the frontend matches the backend
#   only in controlled environments (the secret should not be embedded in public
#   client bundles for browser-run code).
