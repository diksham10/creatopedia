Prompt Table
python
class Prompt(SQLModel, table=True):
    id: uuid.UUID (PK)
    creator_id: uuid.UUID (FK -> creator.id, indexed)
    category_id: uuid.UUID | None (FK -> category.id, indexed)
    title: str
    slug: str (indexed)  # unique per creator
    description: str | None
    content: str  # the actual prompt text (gated)
    ai_tool: str | None  # "ChatGPT", "Midjourney", etc.
    output_type: str | None  # "text", "image", "code"
    thumbnail_url: str | None
    gate_type: str (default="free")  # "free" | "email" | "paid"
    status: str (default="draft")  # "draft" | "published" | "archived"
    view_count: int (default=0)  # denormalized
    copy_count: int (default=0)  # denormalized
    created_at: datetime
    updated_at: datetime
    # Unique constraint: (creator_id, slug)
