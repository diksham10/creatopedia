{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[^.]+)\\.creatopedia\\.tech"
        }
      ],
      "destination": "/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/aggregate",
      "schedule": "0 * * * *"
    }
  ]
}
