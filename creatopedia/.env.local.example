# ============================================
# Subdomain & Multi-tenant Configuration
# ============================================

# Base domain for your application
# For local dev: localhost
# For production: creatopedia.tech
NEXT_PUBLIC_BASE_DOMAIN=localhost

# Backend API configuration
BACKEND_API_URL=http://localhost:8000

# Internal API secret (must match backend configuration)
# Use a secure random string in production
INTERNAL_API_SECRET=dev-secret-change-me-in-production

# ============================================
# Analytics Configuration
# ============================================

# Enable/disable analytics tracking
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# ============================================
# Other Configuration (from existing setup)
# ============================================

# Add your existing variables below...
# NEXT_PUBLIC_API_URL=...
# DATABASE_URL=...
# etc.
